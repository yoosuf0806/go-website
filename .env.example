# Storefront (client-side, exposed to the browser via Vite)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_WHATSAPP_NUMBER=94XXXXXXXXX      # fallback; real value baked into snapshot from site_settings

# Build-time only (NOT exposed to the browser) — used by scripts/snapshot.ts
SUPABASE_SERVICE_KEY=                 # server-side read of catalogue during build; never in client bundle

# Server-side only (Vercel function env, NOT exposed to the browser) —
# read by api/publish.ts, never bundled into the client. The admin "Publish"
# button POSTs to /api/publish, which validates the caller and fires this hook.
ADMIN_DEPLOY_HOOK_URL=                # Vercel Deploy Hook that rebuilds the storefront on "Publish"
